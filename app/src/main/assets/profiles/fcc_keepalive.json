{
  "name": "FCC Keepalive",
  "description": "Re-applies FCC radio mode every 2s over TCP 40009 to prevent DJI Fly from resetting to CE. Uses only TCP-confirmed-working frames.",
  "sender": 130,
  "sender_desc": "MOBILE_APP, index 4",
  "cmd_type": 32,
  "cmd_type_desc": "Request, ACK_BEFORE_EXEC, no encryption",
  "rounds": 1,
  "inter_frame_delay_ms": 100,
  "inter_round_delay_ms": 0,
  "read_window_ms": 80,
  "frames": [
    { "s": 16, "i": 88,  "d": 18,  "p": "030100",             "note": "AUTOTEST enter service mode" },
    { "s": 6,  "i": 114, "d": 6,   "p": "00000000000100",     "note": "RADIO set region to FCC (01)" },
    { "s": 6,  "i": 114, "d": 6,   "p": "000000000001ff",     "note": "RADIO commit region change" },
    { "s": 16, "i": 88,  "d": 18,  "p": "030100",             "note": "AUTOTEST exit service mode" }
  ]
}